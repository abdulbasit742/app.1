# Required outside tests. Generate a random value of at least 32 characters.
SECRET_KEY=

# Optional. Defaults to instance/app.db.
DATABASE_URL=

# Comma-separated exact browser origins. Wildcards are rejected.
CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000
SESSION_COOKIE_SECURE=false
BIND_HOST=127.0.0.1
PORT=5000

# Optional one-time administrator bootstrap. Set both, start once, then remove them.
PES_BOOTSTRAP_ADMIN_EMAIL=
PES_BOOTSTRAP_ADMIN_PASSWORD=
PES_BOOTSTRAP_ADMIN_NAME=PES Administrator
